// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// --- 用户 ---
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  password  String?
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  skills   Skill[]
  posts    BlogPost[]
  comments Comment[]

  @@map("users")
}

// SQLite does not support enums, using String with @default instead
// enum Role {
//   USER
//   ADMIN
// }

// --- 技能分类 ---
model Category {
  id    String  @id @default(cuid())
  name  String  @unique
  slug  String  @unique
  icon  String?
  order Int     @default(0)

  skills Skill[]

  @@map("categories")
}

// --- 标签 ---
model Tag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  skills Skill[]
  posts  BlogPost[]

  @@map("tags")
}

// --- 技能资源 ---
model Skill {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  description   String
  content       String?

  coverImage    String?
  price         Float    @default(0)
  downloadCount Int      @default(0)
  viewCount     Int      @default(0)
  isPublished   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  tags       Tag[]
  files      File[]
  comments   Comment[]

  @@index([categoryId])
  @@index([authorId])
  @@index([slug])
  @@map("skills")
}

// --- 上传文件 ---
model File {
  id        String   @id @default(cuid())
  filename  String
  url       String
  size      Int
  mimeType  String
  createdAt DateTime @default(now())

  skillId String?
  skill   Skill?  @relation(fields: [skillId], references: [id])

  @@map("files")
}

// --- 博客文章 ---
model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  coverImage  String?
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authorId String
  author   User   @relation(fields: [authorId], references: [id])
  tags     Tag[]
  comments Comment[]

  @@index([authorId])
  @@index([slug])
  @@map("blog_posts")
}

// --- 评论 ---
model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  authorId String
  author   User      @relation(fields: [authorId], references: [id])
  
  postId   String?
  post     BlogPost? @relation(fields: [postId], references: [id])
  
  skillId  String?
  skill    Skill?    @relation(fields: [skillId], references: [id])

  @@index([authorId])
  @@index([postId])
  @@index([skillId])
  @@map("comments")
}
